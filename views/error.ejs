<%- include('partials/header') %>

<main id="main-content" class="container error-page">
  <div class="error-content">
    <div class="error-icon" aria-hidden="true">⚠️</div>
    <h1><%= (t && t.errorPageTitle) || 'Erreur' %></h1>
    <h2><%= (t && t.errorTitle) || "Une erreur s'est produite" %></h2>
    <p><%= message || (t && t.errorDefault) || 'Veuillez réessayer plus tard.' %></p>
    <a href="/" class="btn btn-primary"><%= (t && t.backHome) || "Retour à l'accueil" %></a>
  </div>
</main>

<%- include('partials/footer') %>
