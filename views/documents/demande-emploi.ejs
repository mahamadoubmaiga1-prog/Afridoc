<%- include('../partials/header') %>

<main id="main-content" class="container form-page">
  <div class="form-header">
    <nav class="breadcrumb" aria-label="Fil d'Ariane"><a href="/">Accueil</a><span aria-hidden="true"> › </span><span aria-current="page"><%= docTitle %></span></nav>
    <h1>💼 Demande d'emploi</h1>
    <p>Rédigez votre demande d'emploi formelle en PDF.</p>
  </div>

  <form action="/documents/demande-emploi/generate" method="POST" class="doc-form doc-form--themed">

    <%- include('partials/theme-selector') %>

    <fieldset>
      <legend>Vos coordonnées</legend>
      <div class="form-row">
        <div class="form-group">
          <label for="prenom">Prénom *</label>
          <input type="text" id="prenom" name="prenom" required maxlength="100" placeholder="Ex : Seydou">
        </div>
        <div class="form-group">
          <label for="nom">Nom *</label>
          <input type="text" id="nom" name="nom" required maxlength="100" placeholder="Ex : Keïta">
        </div>
      </div>
      <div class="form-group">
        <label for="adresse">Adresse *</label>
        <input type="text" id="adresse" name="adresse" required maxlength="300" placeholder="Ex : Quartier Hamdallaye, Bamako">
      </div>
      <div class="form-row">
        <div class="form-group">
          <label for="telephone">Téléphone *</label>
          <input type="tel" id="telephone" name="telephone" required maxlength="30" placeholder="Ex : +223 76 00 00 00">
        </div>
        <div class="form-group">
          <label for="email">Email</label>
          <input type="email" id="email" name="email" maxlength="200" placeholder="Ex : seydou@email.com">
        </div>
      </div>
      <div class="form-row">
        <div class="form-group">
          <label for="ville">Ville *</label>
          <input type="text" id="ville" name="ville" required maxlength="100" placeholder="Ex : Bamako">
        </div>
        <div class="form-group">
          <label for="date">Date *</label>
          <input type="text" id="date" name="date" required maxlength="50" placeholder="Ex : 14 juin 2024">
        </div>
      </div>
    </fieldset>

    <fieldset>
      <legend>Poste et employeur</legend>
      <div class="form-group">
        <label for="directeur">Nom du directeur / responsable *</label>
        <input type="text" id="directeur" name="directeur" required maxlength="200" placeholder="Ex : M. Sanogo Adama">
      </div>
      <div class="form-group">
        <label for="entreprise">Nom de l'entreprise *</label>
        <input type="text" id="entreprise" name="entreprise" required maxlength="200" placeholder="Ex : Société Minière du Mali">
      </div>
      <div class="form-group">
        <label for="poste">Poste sollicité *</label>
        <input type="text" id="poste" name="poste" required maxlength="200" placeholder="Ex : Technicien de maintenance">
      </div>
    </fieldset>

    <fieldset>
      <legend>Qualifications</legend>
      <div class="form-group">
        <label for="diplome">Diplôme obtenu *</label>
        <input type="text" id="diplome" name="diplome" required maxlength="300" placeholder="Ex : un BTS en Électrotechnique obtenu en 2022">
      </div>
      <div class="form-group">
        <label for="experience">Expérience professionnelle *</label>
        <input type="text" id="experience" name="experience" required maxlength="300" placeholder="Ex : 3 ans dans le secteur industriel">
      </div>
      <div class="form-group">
        <label for="motivation">Motivation (optionnel)</label>
        <textarea id="motivation" name="motivation" rows="5" maxlength="1000"
          placeholder="Expliquez pourquoi vous postulez à ce poste..."></textarea>
      </div>
    </fieldset>
    <%- include('partials/form-actions', { docType: 'demande-emploi', submitLabel: "📥 Générer ma demande en PDF" }) %>
  </form>
</main>

<%- include('../partials/footer') %>
