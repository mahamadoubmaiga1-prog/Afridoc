<%- include('../partials/header') %>

<main id="main-content" class="container form-page">
  <div class="form-header">
    <nav class="breadcrumb" aria-label="Fil d'Ariane"><a href="/">Accueil</a><span aria-hidden="true"> › </span><span aria-current="page"><%= docTitle %></span></nav>
    <h1>🤝 Déclaration sur l'honneur</h1>
    <p>Rédigez votre déclaration sur l'honneur officielle en PDF.</p>
  </div>

  <form action="/documents/declaration-honneur/generate" method="POST" class="doc-form doc-form--themed">

    <%- include('partials/theme-selector') %>

    <fieldset>
      <legend>Identité du déclarant</legend>
      <div class="form-row">
        <div class="form-group">
          <label for="prenom">Prénom *</label>
          <input type="text" id="prenom" name="prenom" required maxlength="100" placeholder="Ex : Moussa">
        </div>
        <div class="form-group">
          <label for="nom">Nom *</label>
          <input type="text" id="nom" name="nom" required maxlength="100" placeholder="Ex : Coulibaly">
        </div>
      </div>
      <div class="form-row">
        <div class="form-group">
          <label for="dateNaissance">Date de naissance *</label>
          <input type="text" id="dateNaissance" name="dateNaissance" required maxlength="100" placeholder="Ex : 12 avril 1990">
        </div>
        <div class="form-group">
          <label for="lieuNaissance">Lieu de naissance *</label>
          <input type="text" id="lieuNaissance" name="lieuNaissance" required maxlength="200" placeholder="Ex : Ségou, Mali">
        </div>
      </div>
      <div class="form-group">
        <label for="adresse">Adresse de résidence *</label>
        <input type="text" id="adresse" name="adresse" required maxlength="300" placeholder="Ex : Bamako, Quartier Médina Coura">
      </div>
      <div class="form-group">
        <label for="profession">Profession</label>
        <input type="text" id="profession" name="profession" maxlength="200" placeholder="Ex : Commerçant(e), Enseignant(e), Étudiant(e)...">
      </div>
    </fieldset>

    <fieldset>
      <legend>Objet de la déclaration</legend>
      <div class="form-group">
        <label for="objet">Objet de la déclaration *</label>
        <input type="text" id="objet" name="objet" required maxlength="500"
          placeholder="Ex : je n'ai jamais fait l'objet d'une condamnation pénale">
      </div>
      <div class="form-group">
        <label for="contenu">Précisions supplémentaires (optionnel)</label>
        <textarea id="contenu" name="contenu" rows="5" maxlength="1000"
          placeholder="Ajoutez des précisions si nécessaire..."></textarea>
      </div>
    </fieldset>

    <fieldset>
      <legend>Lieu et date</legend>
      <div class="form-row">
        <div class="form-group">
          <label for="ville">Ville *</label>
          <input type="text" id="ville" name="ville" required maxlength="100" placeholder="Ex : Bamako">
        </div>
        <div class="form-group">
          <label for="date">Date *</label>
          <input type="text" id="date" name="date" required maxlength="50" placeholder="Ex : 14 juin 2024">
        </div>
      </div>
    </fieldset>
    <%- include('partials/form-actions', { docType: 'declaration-honneur', submitLabel: "📥 Générer ma déclaration en PDF" }) %>
  </form>
</main>

<%- include('../partials/footer') %>
