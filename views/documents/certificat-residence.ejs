<%- include('../partials/header') %>

<main class="container form-page">
  <div class="form-header">
    <a href="/" class="back-link">← Retour à l'accueil</a>
    <h1>🏠 Certificat de résidence</h1>
    <p>Renseignez les informations nécessaires pour votre certificat de résidence.</p>
  </div>

  <form action="/documents/certificat-residence/generate" method="POST" class="doc-form doc-form--themed">

    <%- include('partials/theme-selector') %>

    <fieldset>
      <legend>Identité</legend>
      <div class="form-row">
      <div class="form-group">
        <label for="prenom">Prénom *</label>
        <input type="text" id="prenom" name="prenom" required maxlength="200" data-help="Ce champ sera affiché dans le document final." placeholder="Ex : Yacouba">
      </div>
      <div class="form-group">
        <label for="nom">Nom *</label>
        <input type="text" id="nom" name="nom" required maxlength="200" data-help="Ce champ sera affiché dans le document final." placeholder="Ex : Sanogo">
      </div>
      </div>
      <div class="form-row">
      <div class="form-group">
        <label for="adresse">Adresse *</label>
        <input type="text" id="adresse" name="adresse" required maxlength="200" data-help="Ce champ sera affiché dans le document final." placeholder="Ex : Rue 245, Faladié">
      </div>
      <div class="form-group">
        <label for="quartier">Quartier *</label>
        <input type="text" id="quartier" name="quartier" required maxlength="200" data-help="Ce champ sera affiché dans le document final." placeholder="Ex : Faladié">
      </div>
      </div>
      <div class="form-row">
      <div class="form-group">
        <label for="commune">Commune *</label>
        <input type="text" id="commune" name="commune" required maxlength="200" data-help="Ce champ sera affiché dans le document final." placeholder="Ex : Commune VI">
      </div>
      <div class="form-group">
        <label for="ville">Ville *</label>
        <input type="text" id="ville" name="ville" required maxlength="200" data-help="Ce champ sera affiché dans le document final." placeholder="Ex : Bamako">
      </div>
      </div>
    </fieldset>

    <fieldset>
      <legend>Informations complémentaires</legend>
      <div class="form-row">
      <div class="form-group">
        <label for="dateNaissance">Date de naissance *</label>
        <input type="text" id="dateNaissance" name="dateNaissance" required maxlength="200" data-help="Ce champ sera affiché dans le document final." placeholder="Ex : 9 septembre 1992">
      </div>
      <div class="form-group">
        <label for="lieuNaissance">Lieu de naissance *</label>
        <input type="text" id="lieuNaissance" name="lieuNaissance" required maxlength="200" data-help="Ce champ sera affiché dans le document final." placeholder="Ex : Ségou">
      </div>
      </div>
      <div class="form-row">
      <div class="form-group">
        <label for="nationalite">Nationalité *</label>
        <input type="text" id="nationalite" name="nationalite" required maxlength="200" data-help="Ce champ sera affiché dans le document final." placeholder="Ex : Malienne">
      </div>
      <div class="form-group">
        <label for="profession">Profession *</label>
        <input type="text" id="profession" name="profession" required maxlength="200" data-help="Ce champ sera affiché dans le document final." placeholder="Ex : Enseignant">
      </div>
      </div>
      <div class="form-row">
      <div class="form-group">
        <label for="usage">Usage du certificat *</label>
        <textarea id="usage" name="usage" rows="5" maxlength="2000" required data-help="Ce champ sera affiché dans le document final." placeholder="Ex : Constitution d'un dossier bancaire"></textarea>
      </div>
      <div class="form-group">
        <label for="nombreCopies">Nombre de copies *</label>
        <input type="number" id="nombreCopies" name="nombreCopies" required maxlength="200" min="1" data-help="Ce champ sera affiché dans le document final." placeholder="Ex : 2">
      </div>
      </div>
      <div class="form-group">
        <label for="date">Date *</label>
        <input type="text" id="date" name="date" required maxlength="200" data-help="Ce champ sera affiché dans le document final." placeholder="Ex : 14 juin 2024">
      </div>
    </fieldset>

    <%- include('partials/form-actions', { docType: 'certificat-residence', submitLabel: "📥 Générer le certificat en PDF" }) %>
  </form>
</main>

<%- include('../partials/footer') %>
