<%- include('../partials/header') %>

<main id="main-content" class="container form-page">
  <div class="form-header">
    <nav class="breadcrumb" aria-label="Fil d'Ariane"><a href="/">Accueil</a><span aria-hidden="true"> › </span><span aria-current="page"><%= docTitle %></span></nav>
    <h1>🌴 Demande de congé</h1>
    <p>Préparez une demande de congé professionnelle en quelques clics.</p>
  </div>

  <form action="/documents/demande-conge/generate" method="POST" class="doc-form doc-form--themed">

    <%- include('partials/theme-selector') %>

    <fieldset>
      <legend>Employé</legend>
      <div class="form-row">
      <div class="form-group">
        <label for="prenom">Prénom *</label>
        <input type="text" id="prenom" name="prenom" required maxlength="200" data-help="Ce champ sera affiché dans le document final." placeholder="Ex : Aminata">
      </div>
      <div class="form-group">
        <label for="nom">Nom *</label>
        <input type="text" id="nom" name="nom" required maxlength="200" data-help="Ce champ sera affiché dans le document final." placeholder="Ex : Maïga">
      </div>
      </div>
      <div class="form-row">
      <div class="form-group">
        <label for="poste">Poste *</label>
        <input type="text" id="poste" name="poste" required maxlength="200" data-help="Ce champ sera affiché dans le document final." placeholder="Ex : Comptable">
      </div>
      <div class="form-group">
        <label for="service">Service *</label>
        <input type="text" id="service" name="service" required maxlength="200" data-help="Ce champ sera affiché dans le document final." placeholder="Ex : Finance">
      </div>
      </div>
      <div class="form-group">
        <label for="entreprise">Entreprise *</label>
        <input type="text" id="entreprise" name="entreprise" required maxlength="200" data-help="Ce champ sera affiché dans le document final." placeholder="Ex : Société Sahel Services">
      </div>
    </fieldset>

    <fieldset>
      <legend>Congé</legend>
      <div class="form-row">
      <div class="form-group">
        <label for="typeConge">Type de congé *</label>
        <select id="typeConge" name="typeConge" required data-help="Ce champ sera affiché dans le document final.">
          <option value="">Sélectionnez</option>
            <option value="annuel">annuel</option>
            <option value="maladie">maladie</option>
            <option value="maternité">maternité</option>
            <option value="paternité">paternité</option>
            <option value="autre">autre</option>
        </select>
      </div>
      <div class="form-group">
        <label for="dateDebut">Date de début *</label>
        <input type="text" id="dateDebut" name="dateDebut" required maxlength="200" data-help="Ce champ sera affiché dans le document final." placeholder="Ex : 1er août 2024">
      </div>
      </div>
      <div class="form-row">
      <div class="form-group">
        <label for="dateFin">Date de fin *</label>
        <input type="text" id="dateFin" name="dateFin" required maxlength="200" data-help="Ce champ sera affiché dans le document final." placeholder="Ex : 15 août 2024">
      </div>
      <div class="form-group">
        <label for="nombreJours">Nombre de jours *</label>
        <input type="number" id="nombreJours" name="nombreJours" required maxlength="200" min="1" data-help="Ce champ sera affiché dans le document final." placeholder="Ex : 15">
      </div>
      </div>
      <div class="form-row">
      <div class="form-group">
        <label for="motif">Motif *</label>
        <textarea id="motif" name="motif" rows="5" maxlength="2000" required data-help="Ce champ sera affiché dans le document final." placeholder="Précisez le motif de votre demande."></textarea>
      </div>
      <div class="form-group">
        <label for="directeur">Nom du responsable *</label>
        <input type="text" id="directeur" name="directeur" required maxlength="200" data-help="Ce champ sera affiché dans le document final." placeholder="Ex : M. Coulibaly, Directeur">
      </div>
      </div>
      <div class="form-row">
      <div class="form-group">
        <label for="ville">Ville *</label>
        <input type="text" id="ville" name="ville" required maxlength="200" data-help="Ce champ sera affiché dans le document final." placeholder="Ex : Mopti">
      </div>
      <div class="form-group">
        <label for="date">Date *</label>
        <input type="text" id="date" name="date" required maxlength="200" data-help="Ce champ sera affiché dans le document final." placeholder="Ex : 14 juin 2024">
      </div>
      </div>
    </fieldset>

    <%- include('partials/form-actions', { docType: 'demande-conge', submitLabel: "📥 Générer la demande en PDF" }) %>
  </form>
</main>

<%- include('../partials/footer') %>
