<%- include('partials/header') %>

<main>
  <section class="hero">
    <div class="hero-content">
      <h1 class="hero-title"><%= (t && t.heroTitle) || 'Bienvenue sur' %> <span class="highlight">Afridoc</span></h1>
      <p class="hero-sub"><%= (t && t.heroSubtitle) || 'Générez vos documents administratifs en quelques clics, sans vous déplacer au cybercafé.' %></p>
      <a href="#documents" class="btn btn-primary"><%= (t && t.startNow) || 'Commencer maintenant' %></a>
    </div>
    <div class="hero-graphic" aria-hidden="true">
      <div class="hero-icon">📋</div>
    </div>
  </section>

  <section class="stats-bar">
    <div class="container stats-bar-inner">
      <strong><%= stats.total %></strong>
      <span>documents générés par nos utilisateurs</span>
    </div>
  </section>

  <section class="how-it-works container">
    <h2 class="section-title"><%= (t && t.howItWorks) || 'Comment ça marche ?' %></h2>
    <div class="steps">
      <div class="step">
        <div class="step-num">1</div>
        <h3><%= (t && t.step1Title) || 'Choisissez' %></h3>
        <p><%= (t && t.step1Text) || 'Sélectionnez le type de document que vous souhaitez créer.' %></p>
      </div>
      <div class="step">
        <div class="step-num">2</div>
        <h3><%= (t && t.step2Title) || 'Remplissez' %></h3>
        <p><%= (t && t.step2Text) || 'Saisissez vos informations dans le formulaire simple et guidé.' %></p>
      </div>
      <div class="step">
        <div class="step-num">3</div>
        <h3><%= (t && t.step3Title) || 'Téléchargez' %></h3>
        <p><%= (t && t.step3Text) || 'Obtenez votre document en PDF prêt à imprimer ou à envoyer.' %></p>
      </div>
    </div>
  </section>

  <section id="documents" class="documents container">
    <h2 class="section-title"><%= (t && t.documentsTitle) || 'Choisissez votre document' %></h2>
    <div class="doc-grid">
      <a href="/documents/cv" class="doc-card"><div class="doc-icon">👤</div><h3>CV</h3><p>Curriculum Vitae professionnel</p></a>
      <a href="/documents/lettre-motivation" class="doc-card"><div class="doc-icon">✉️</div><h3>Lettre de motivation</h3><p>Pour accompagner votre candidature</p></a>
      <a href="/documents/demande-emploi" class="doc-card"><div class="doc-icon">💼</div><h3>Demande d'emploi</h3><p>Lettre de demande d'emploi</p></a>
      <a href="/documents/demande-stage" class="doc-card"><div class="doc-icon">🎓</div><h3>Demande de stage</h3><p>Demande de stage académique</p></a>
      <a href="/documents/attestation-travail" class="doc-card"><div class="doc-icon">📜</div><h3>Attestation de travail</h3><p>Attestation délivrée par l'employeur</p></a>
      <a href="/documents/declaration-honneur" class="doc-card"><div class="doc-icon">🤝</div><h3>Déclaration sur l'honneur</h3><p>Déclaration officielle sur l'honneur</p></a>
      <a href="/documents/lettre-administrative" class="doc-card"><div class="doc-icon">🏛️</div><h3>Lettre administrative</h3><p>Correspondance avec les administrations</p></a>
      <a href="/documents/demande-acte-naissance" class="doc-card"><div class="doc-icon">🪪</div><h3>Demande d'acte de naissance</h3><p>Demande auprès de l'état civil</p></a>
      <a href="/documents/contrat-travail" class="doc-card"><div class="doc-icon">🧾</div><h3>Contrat de travail</h3><p>Contrat professionnel employeur-salarié</p></a>
      <a href="/documents/recu-paiement" class="doc-card"><div class="doc-icon">💳</div><h3>Reçu de paiement</h3><p>Justificatif de règlement</p></a>
      <a href="/documents/procuration" class="doc-card"><div class="doc-icon">🖊️</div><h3>Procuration</h3><p>Mandat de représentation</p></a>
      <a href="/documents/demande-conge" class="doc-card"><div class="doc-icon">🌴</div><h3>Demande de congé</h3><p>Demande officielle d'absence</p></a>
      <a href="/documents/certificat-residence" class="doc-card"><div class="doc-icon">🏠</div><h3>Certificat de résidence</h3><p>Attestation de domicile</p></a>
      <a href="/documents/lettre-recommandation" class="doc-card"><div class="doc-icon">🌟</div><h3>Lettre de recommandation</h3><p>Appui professionnel et académique</p></a>
      <a href="/documents/mise-en-demeure" class="doc-card"><div class="doc-icon">⚖️</div><h3>Mise en demeure</h3><p>Notification formelle avant recours</p></a>
      <a href="/documents/attestation-scolarite" class="doc-card"><div class="doc-icon">🏫</div><h3>Attestation de scolarité</h3><p>Justificatif de fréquentation scolaire</p></a>
    </div>
  </section>

  <section class="features container">
    <h2 class="section-title"><%= (t && t.whyChoose) || 'Pourquoi choisir Afridoc ?' %></h2>
    <div class="features-grid">
      <div class="feature"><span class="feature-icon">⚡</span><h3>Rapide</h3><p>Générez votre document en moins de 2 minutes.</p></div>
      <div class="feature"><span class="feature-icon">🆓</span><h3>Gratuit</h3><p>Aucun frais, aucune inscription requise.</p></div>
      <div class="feature"><span class="feature-icon">📲</span><h3>Accessible</h3><p>Depuis votre téléphone, tablette ou ordinateur.</p></div>
      <div class="feature"><span class="feature-icon">🔒</span><h3>Sécurisé</h3><p>Vos données ne sont jamais stockées sur nos serveurs.</p></div>
    </div>
  </section>
</main>

<%- include('partials/footer') %>
