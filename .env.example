# Environment Configuration for Afridoc

# Backend - Neon Database (PostgreSQL)
DATABASE_URL=******ep-xxxx-xxxx.neon.tech/afridoc

# Server Configuration
NODE_ENV=development
PORT=3000

# API Configuration
BACKEND_URL=http://localhost:3000
FRONTEND_URL=http://localhost:3000

# Production URLs (for Vercel/Neon deployment)
# BACKEND_URL=https://afridoc-backend.neon.tech
# FRONTEND_URL=https://afridoc.vercel.app

# Optional: Add any external APIs or services
# API_KEY=your_api_key_here
